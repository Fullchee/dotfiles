Host github.com
    HostName ssh.github.com
    Port 443
    User git
    IdentityFile ~/.ssh/id_ed25519

Host gcloud-workstation
    HostName localhost
    Port 2222
    User user
    # known_host issue as not required for SSH tunnel
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    # ForwardX11 yes
    # ForwardX11Trusted yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

Host pihole
    HostName 192.168.50.8
    User pihole
    AddKeysToAgent yes
    {{ if eq .chezmoi.os "darwin" -}}
    UseKeychain yes
    {{- end }}
    # ForwardX11 yes
    # ForwardX11Trusted yes


Host server
    HostName 192.168.50.11
    User fullchee
    AddKeysToAgent yes
    {{ if eq .chezmoi.os "darwin" -}}
    UseKeychain yes
    {{- end }}
    # ForwardX11 yes
    # ForwardX11Trusted yes
