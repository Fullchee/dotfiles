    eval "$(pyenv init -)"
fi

LATEST=$(pyenv install --list | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | tail -1)
pyenv install -s "$LATEST"
pyenv global "$LATEST"
pyenv local "$LATEST"

# optional extras (postgres, mysql, docker, etc.)
sudo apt-get install -y postgresql postgresql-contrib
sudo -u postgres createuser -s "$USER" || true
sudo -u postgres createdb "$USER" || true

# install pipx/uv tooling
python3 -m pip install --user pipx
python3 -m pipx ensurepath
~/.local/bin/pipx install uv  # or use curl installer for uv

# snaps (if you like)
if command -v snap >/dev/null; then
    sudo snap install go --classic
    sudo snap install node --classic
fi

# finish up
sudo rm /etc/sudoers.d/timeout
echo "Ubuntu bootstrap complete.  Log out and back in if you changed shell."

{{- end }}

osascript -e 'tell app "System Events" to log out'

# add to /etc/hosts to block certain sites

echo "0.0.0.0     www.webtoons.com webtoons.com" | sudo tee -a /etc/hosts
sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder  # flush DNS

sudo chflags schg /etc/hosts  # makes the file immutable, can't sudo


# Remove the temporary timeout when done
sudo rm /etc/sudoers.d/timeout
