#!/bin/zsh

{{- if eq .chezmoi.os "darwin" }}
# macOS-specific installation steps sourced from the shared bootstrap
# script.  These assume $OS has already been set to "darwin" by the
# caller.

# bootstrap helpers ----------------------------------------------------------
# Extend sudo timeout to 120 minutes (handled by parent script).
# Install Homebrew if it's not already available.
if ! command -v brew &> /dev/null; then
  echo "Installing homebrew"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Apple silicon
  if [ -d /opt/homebrew/bin ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  # intel
  elif [ -d /usr/local/bin ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

brew update

# cask/app installs (mac only) --------------------------------------------
install_cask adobe-acrobat-reader
install_cask anki
install_cask balenaetcher
install_cask cap
install_cask chatgpt
install_cask claude
install_cask db-browser-for-sqlite
install_cask dbngin
install_cask discord
install_cask docker
install_cask figma
install_cask finicky
install_cask firefox

# firefox policies
if [ "$OS" = darwin ]; then
  mkdir -p ~/Library/Application\ Support/Firefox/distribution
  cp ~/.dotfiles/post-install/browser/firefox-policies.json ~/Library/Application\ Support/Firefox/distribution/policies.json
fi

install_cask font-hack-nerd-font
install_cask font-jetbrains-mono
install_cask freedom
install_cask google-chrome
install_cask handbrake
install_cask imageoptim
install_cask iina
install_cask iterm2
install_cask jordanbaird-ice
install_cask karabiner-elements
install_cask keycastr
install_cask modern-csv
install_cask notion
install_cask obsidian
install_cask raspberry-pi-imager
install_cask raycast
install_cask rectangle
install_cask sejda-pdf
install_cask sublime-text
install_cask tableplus
install_cask todoist
install_cask visual-studio-code
install_cask wechat
install_cask whatsapp
install_cask wispr-flow
install_cask zoom

if [ "$OS" = darwin ]; then
  mas install 1440147259
  mas install 937984704
  wget https://github.com/x74353/Amphetamine-Enhancer/raw/master/Releases/Current/Amphetamine%20Enhancer.dmg
  hdiutil attach Amphetamine\ Enhancer.dmg
  cp -R /Volumes/Amphetamine\ Enhancer/Amphetamine\ Enhancer.app /Applications
  mas install 1352778147
  mas install 540348655
  mas install 1406676254
  mas install 1122008420
fi

# os-specific final tweaks --------------------------------------------------
if [ "$OS" = darwin ]; then
  osascript -e 'tell app "System Events" to log out'
  echo "0.0.0.0     www.webtoons.com webtoons.com" | sudo tee -a /etc/hosts
  sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder
  sudo chflags schg /etc/hosts
fi

# Remove the temporary timeout when done
sudo rm /etc/sudoers.d/timeout
