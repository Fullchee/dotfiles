#!/bin/zsh

set -euo pipefail

# extend sudo timeout for this script only (120 minutes)
sudo sh -c 'echo "Defaults timestamp_timeout=120" > /etc/sudoers.d/timeout'

IS_MAC={{ if eq .chezmoi.os "darwin" }}true{{ else }}false{{ end }}
IS_LINUX={{ if eq .chezmoi.os "linux" }}true{{ else }}false{{ end }}

install_pkg() {
  if $IS_MAC; then
    brew install "$@"       # shortcuts, no "-y"
  elif $IS_LINUX; then
    sudo apt-get install -y "$@"  # apt always -y
  else
    echo "[install_pkg] only works for Linux and Mac" >&2
    exit 1
  fi
}

# download rust
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
. "$HOME/.cargo/env"  # add cargo to current session to install software below

export CARGO_NET_GIT_FETCH_WITH_CLI=true

# uv needed here to install other global python packages below
if ! command -v uv >/dev/null; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
  uv python install --default
fi

# bootstrap helpers ----------------------------------------------------------
if $IS_MAC; then
  # Extend sudo timeout to 120 minutes
  if ! command -v brew &> /dev/null; then
    echo "Installing homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Apple silicon
    if [ -d /opt/homebrew/bin ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    # intel
    elif [ -d /usr/local/bin ]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  fi

  brew update
  export HOMEBREW_NO_AUTO_UPDATE=1  # when you run `brew install`, don't run `brew update` first, we already did it here
fi

if $IS_LINUX; then
  sudo apt-get update -y
  sudo apt-get upgrade -y
fi

# platform-independent package installs -------------------------------------

# adb
if $IS_LINUX; then
  sudo apt update && sudo apt install android-tools-adb android-tools-fastboot
elif $IS_MAC; then
  brew install --cask android-platform-tools
fi

install_pkg age       # file encryption for chezmoi

{{- if eq .chezmoi.hostname "Fullchee-Citylitics" }}
install_pkg ansible   # Automate deployment, configuration, and upgrading
{{- end }}

uv tool install bandit  # security linter
install_pkg bash      # apple ships bash 3, linux has newer version

install_pkg bat       # better cat
if $IS_LINUX; then
  # on linux, bat is called "batcat" to avoid conflict with another package
  if [ ! -e /usr/local/bin/bat ]; then
      sudo ln -s "$(command -v batcat)" /usr/local/bin/bat
  fi
fi

if $IS_LINUX; then
  sudo apt install build-essential  # for cargo install to work on linux, provides cc for compiling dependencies
fi

sh -c "$(curl -fsLS get.chezmoi.io)"
cargo install --locked cargo-update  # manage cargo-installed binaries, `cargo install-update -a` to update them all
install_pkg coreutils
cargo install --locked choose  # eg: easily get the 3rd item in each line
cargo install --locked difftastic  # better git diff
install_pkg eza       # better ls & tree with icons
cargo install --locked fd-find  # faster find
install_pkg ffmpeg
install_pkg fzf       # interactive filter

install_pkg git       # up-to-date git
install_pkg gh        # GitHub CLI
install_pkg git-filter-repo  # remove a file from git history
install_pkg git-delta  # git pager, works better for larger files as a pager than difftastic

if $IS_MAC; then
  install_pkg graphviz  # generate (DB) diagrams (eg: DBeaver to generate ER diagrams)
fi

if $IS_LINUX; then
  sudo add-apt-repository -y ppa:maveonair/helix-editor
  sudo apt update
fi
install_pkg helix  # vim with batteries included, no need to manage plugins
uv tool install httpie  # test APIs from terminal, like Postman but CLI
install_pkg hyperfine # command benchmarking
install_pkg imagemagick  # like ffmpeg for images
install_pkg jc        # convert plain text data into JSON (to plug into jq)
install_pkg jq        # JSON processor
install_pkg just      # a better `Make` and `Makefile` replacement for tasks

curl https://mise.run | sh
eval "$(~/.local/bin/mise activate zsh)"  # activate it for this session

install_pkg mosh      # ssh for bad (mobile) connections

# node environment ----------------------------------------------------
mise use -g node@lts
npm i -g corepack@latest
npm i -g npm
corepack enable pnpm
corepack use pnpm@latest

install_pkg pgcli
if $IS_MAC; then
  POSTGRES_NAME=$(brew formulae | grep postgresql@ | tail -1)
  install_pkg "$POSTGRES_NAME"
  brew services start postgresql
else
  install_pkg postgresql postgresql-contrib
fi
createuser -s postgres
createuser -s "$USER"
createdb "$USER"

cargo install --locked prek
prek install || true

# python ------------------------------------------------------------------
uv tool install ptpython
uv tool install pyright  # type checker that's faster than mypy
uv tool install rich-cli # highlight and format text
install_pkg ripgrep   # faster grep
uv tool install ruff@latest
install_pkg sd        # faster sed
install_pkg shellcheck
install_pkg shfmt
uv tool install sqlfluff

cargo install --locked tealdeer  # prompt
tldr --update

install_pkg tmux
install_pkg ugrep   # drop-in grep API when LLM still uses grep
install_pkg vim

# weave: language aware merger
cargo install --git https://github.com/Ataraxy-Labs/weave weave-cli
cargo install --git https://github.com/Ataraxy-Labs/weave weave-driver
weave setup

install_pkg wget

# yt-dlp
rm -rf "$HOME/.local/bin/yt-dlp"
{{ if eq .chezmoi.os "darwin" }}
curl -fsSL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_macos -o "$HOME/.local/bin/yt-dlp"
{{ else }}
curl -fsSL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o "$HOME/.local/bin/yt-dlp"
{{ end }}
chmod +x "$HOME/.local/bin/yt-dlp"

install_pkg zoxide
install_pkg zsh

if [ ! -d "${ZDOTDIR:-$HOME}/.zprezto" ]; then
  git clone --recursive https://github.com/sorin-ionescu/prezto.git "${ZDOTDIR:-$HOME}/.zprezto"
  config config --local status.showUntrackedFiles no
  echo 'source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"' >> ~/.zshrc

  touch ~/.lc_history

  zsh

  setopt EXTENDED_GLOB
  for rcfile in "${ZDOTDIR:-$HOME}"/.zprezto/runcoms/^README.md(.N); do
    ln -sf "$rcfile" "${ZDOTDIR:-$HOME}/.${rcfile:t}"
  done
fi


# create the folder if it doesn't exist
mkdir -p ~/projects


# Remove the temporary timeout when done
sudo rm /etc/sudoers.d/timeout
