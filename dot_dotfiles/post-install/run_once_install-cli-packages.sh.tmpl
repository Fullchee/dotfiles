#!/bin/zsh

# extend sudo timeout for this script only (120 minutes)
sudo sh -c 'echo "Defaults timestamp_timeout=120" > /etc/sudoers.d/timeout'

# single template for both macOS and Ubuntu; define helpers to avoid
# duplicating package lines. ugly branching is okay because the helper
# functions centralize commands.

OS={{- if eq .chezmoi.os "darwin" }}darwin{{- else if eq .chezmoi.os "linux" }}linux{{- else }}unknown{{- end }}

install_pkg() {
  case "$OS" in
    darwin) brew install "$@" ;;       # shortcuts, no "-y"
    linux)  sudo apt-get install -y "$@" ;; # apt always -y
    *)      echo "[install_pkg] unsupported OS: $OS" ;;
  esac
}

# bootstrap helpers ----------------------------------------------------------
if [ "$OS" = darwin ]; then
  # Extend sudo timeout to 120 minutes
  if ! command -v brew &> /dev/null; then
    echo "Installing homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Apple silicon
    if [ -d /opt/homebrew/bin ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    # intel
    elif [ -d /usr/local/bin ]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  fi

  brew update
fi

if [ "$OS" = linux ]; then
  sudo apt-get update -y
  sudo apt-get upgrade -y
fi

# platform-independent package installs -------------------------------------
install_pkg age       # file encryption for chezmoi

{{- if eq .chezmoi.hostname "Fullchee-Citylitics" }}
install_pkg ansible   # Automate deployment, configuration, and upgrading
{{- end }}

install_pkg bash      # apple ships bash 3, linux has newer version
install_pkg bat       # better cat
install_pkg chezmoi   # dotfiles manager
install_pkg coreutils
install_pkg choose-rust  # eg: easily get the 3rd item in each line
install_pkg difftastic  # better git diff
install_pkg duckdb    # embeddable SQL OLAP
install_pkg duti      # set default applications (mac only)
install_pkg entr      # run commands when files change
install_pkg eza       # better ls & tree with icons

install_pkg fd        # on linux it's fd-find
if [ "$OS" = linux ]; then
  # make fd available as 'fd' (Ubuntu packages it as fdfind)
  if [ ! -e /usr/local/bin/fd ]; then
      sudo ln -s "$(command -v fdfind)" /usr/local/bin/fd
  fi
fi

install_pkg fzf       # interactive filter
install_pkg ffmpeg

install_pkg git       # up-to-date git
install_pkg gh        # GitHub CLI
install_pkg git-filter-repo  # remove a file from git history
install_pkg git-delta  # git pager, works better for larger files as a pager than difftastic

install_pkg graphviz
install_pkg helix
install_pkg hwatch
install_pkg hyperfine # command benchmarking
install_pkg imagemagick
install_pkg jc        # convert plain text data into JSON (to plug into jq)
install_pkg jq        # JSON processor
install_pkg just      # a better `Make` and `Makefile` replacement for tasks
install_pkg mosh      # ssh for bad (mobile) connections

{{- if eq .chezmoi.hostname "Fullchee-Citylitics" }}
install_pkg mycli     # mysql CLI with completion
install_pkg mysql@8.4 # versioned formula / package
{{- end }}

# node environment (fnm) ----------------------------------------------------
if [ ! -d "$HOME/.fnm" ]; then
  curl -fsSL https://fnm.vercel.app/install | bash
  . "$HOME/.fnm/fnm.sh"
fi
fnm install --lts
fnm default lts-latest
npm install --global corepack@latest
corepack enable pnpm
corepack use pnpm@latest
install_pkg ni        # figures out npm/pnpm/yarn

install_pkg pgcli
if [ "$OS" = darwin ]; then
  POSTGRES_NAME=$(brew formulae | grep postgresql@ | tail -1)
  install_pkg "$POSTGRES_NAME"
  brew services start postgresql

  /opt/homebrew/opt/$POSTGRES_NAME/bin/createdb "$USER"
  /opt/homebrew/bin/createuser -s postgres
else
  install_pkg postgresql postgresql-contrib
  sudo -u postgres createuser -s "$USER" || true
  sudo -u postgres createdb "$USER" || true
fi

install_pkg prek     # faster pre-commit

# python ------------------------------------------------------------------
install_pkg pyenv
pyenv init
LATEST_PYTHON_VERSION=$(pyenv install --list | grep --extended-regexp "^\s*[0-9][0-9.]*[0-9]\s*$" | tail -1 | tr -d ' ')
pyenv install -s $LATEST_PYTHON_VERSION
pyenv global $LATEST_PYTHON_VERSION
pyenv local $LATEST_PYTHON_VERSION
install_pkg pipx

install_pkg ripgrep
install_pkg shellcheck
install_pkg shfmt

install_pkg tealdeer
tldr --update

install_pkg ugrep

# uv (Python tool manager)
if ! command -v uv >/dev/null; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi
uv tool install ptpython
uv tool install sqlfluff

install_pkg vim
install_pkg wget
install_pkg zoxide

# TODO: use blocked-domains repo to do this instead
# add to /etc/hosts to block certain sites
echo "0.0.0.0     www.webtoons.com webtoons.com" | sudo tee -a /etc/hosts
sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder  # flush DNS

sudo chflags schg /etc/hosts  # makes the file immutable, can't sudo



# common post‑install actions ------------------------------------------------
alias config='/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME' $@
rm -rf ~/.zprezto
rm -rf ~/.zprofile

git clone --recursive https://github.com/sorin-ionescu/prezto.git "${ZDOTDIR:-$HOME}/.zprezto"
config config --local status.showUntrackedFiles no
echo 'source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"' >> ~/.zshrc
config reset --hard origin/main

touch ~/.lc_history

setopt EXTENDED_GLOB
for rcfile in "${ZDOTDIR:-$HOME}"/.zprezto/runcoms/^README.md(.N); do
  ln -sf "$rcfile" "${ZDOTDIR:-$HOME}/.${rcfile:t}"
done

# create the folder if it doesn't exist
mkdir -p ~/projects
cd ~/projects
git clone git@github.com:Fullchee/notes.git
cd -


# Remove the temporary timeout when done
sudo rm /etc/sudoers.d/timeout
