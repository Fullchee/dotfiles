####################### CI/CD #######################

watch-cloud-build() {
    if [[ -z "$1" ]]; then
        echo "Usage: watch-cloud-build <commit-sha>"
        return 1
    fi

    local commit_sha="$1"
    local build_id
    local build_status
    local poll_interval=30

    echo "Waiting for Cloud Build to appear for commit ${commit_sha}..."

    # Wait for a build matching the SHA to be registered
    while true; do
        build_id=$(gcloud builds list \
            --filter="substitutions.COMMIT_SHA=${commit_sha}" \
            --limit=1 \
            --format="value(id)" 2>/dev/null)

        if [[ -n "$build_id" ]]; then
            break
        fi
        echo "No build found yet, retrying in ${poll_interval}s..."
        sleep "$poll_interval"
    done

    echo "Watching build ${build_id}..."

    # Poll until a terminal status is reached
    while true; do
        build_status=$(gcloud builds describe "$build_id" \
            --format="value(status)" 2>/dev/null)

        echo "  Status: ${build_status}"

        case "$build_status" in
        SUCCESS)
            say "Cloud Build succeeded"
            echo "✅ Build succeeded: ${build_id}"
            open-deploy-url "$build_id"
            return 0
            ;;
        FAILURE | CANCELLED | TIMEOUT | INTERNAL_ERROR | EXPIRED)
            say "Cloud Build failed"
            echo "❌ Build ${build_status}: ${build_id}"
            open-deploy-url "$build_id"
            return 1
            ;;
        esac

        sleep "$poll_interval"
    done
}

open-deploy-url() {
    if [[ -z "$1" ]]; then
        echo "Usage: open-deploy-url <build-id>"
        return 1
    fi

    local build_id="$1"

    local build_json
    build_json=$(gcloud builds describe "$build_id" --format=json 2>/dev/null)

    local project_id
    project_id=$(printf '%s' "$build_json" | jq -r '.projectId')

    local build_url="https://console.cloud.google.com/cloud-build/builds;region=global/${build_id}?project=${project_id}"

    # Find the index of the first failed step
    local failed_step
    failed_step=$(printf '%s' "$build_json" |
        jq -r '[(.steps // []) | to_entries[] | select(.value.status == "FAILURE") | .key] | first // empty')

    if [[ -n "$failed_step" ]]; then
        local step_url="https://console.cloud.google.com/cloud-build/builds;region=global/${build_id};step=${failed_step}?project=${project_id}"
        echo "Opening failed step ${failed_step}: ${step_url}"
        open "$step_url"
    else
        echo "Opening build: ${build_url}"
        open "$build_url"
    fi
}

_resolve_and_check_origin_sha() {
    local repo_root="$1" input_commit_sha="$2"
    local sha
    if ! sha=$(git -C "$repo_root" rev-parse --verify "$input_commit_sha^{commit}" 2>/dev/null); then
        echo "Error: commit '$input_commit_sha' not found in local repo." >&2
        return 1
    fi
    git -C "$repo_root" fetch origin --quiet 2>/dev/null
    if ! git -C "$repo_root" branch -r --contains "$sha" 2>/dev/null | grep -q "origin/"; then
        echo "Error: $sha is not on origin. Did you forget to git push?" >&2
        return 1
    fi
    printf '%s' "$sha"
}

_deploy-sha() {
    local trigger="$1"
    local project="$2"
    local input_commit_sha="$3"

    local REPO_ROOT
    REPO_ROOT=$(citylitics-repo-root) || return 1

    local commit_sha
    commit_sha=$(_resolve_and_check_origin_sha "$REPO_ROOT" "$input_commit_sha") || return 1
    echo "Resolved commit SHA: $commit_sha"

    local commit_author
    commit_author=$(git -C "$REPO_ROOT" show -s --format='%an <%ae>' "$commit_sha")
    local commit_date
    commit_date=$(git -C "$REPO_ROOT" show -s --format='%ad' --date=iso-strict "$commit_sha")
    local commit_subject
    commit_subject=$(git -C "$REPO_ROOT" show -s --format='%s' "$commit_sha")
    local commit_branches
    commit_branches=$(git -C "$REPO_ROOT" branch --all --contains "$commit_sha" | sed 's#^..##' | sort | paste -sd ', ' -)
    if [[ -z "$commit_branches" ]]; then
        commit_branches="(none)"
    fi
    echo "  Author: $commit_author"
    echo "  Date:   $commit_date"
    echo "  Subject: $commit_subject"
    echo "  Branches containing commit: $commit_branches"

    local output
    output=$(gcloud builds triggers run "$trigger" --project="$project" --sha="$commit_sha" --format=json)
    echo "$output"

    local build_id
    build_id=$(echo "$output" | jq -r '.metadata.build.id')
    if [[ -n "$build_id" && "$build_id" != "null" ]]; then
        local url="https://console.cloud.google.com/cloud-build/builds;region=global/${build_id}?project=${project}"
        echo "Opening: $url"
        open "$url"
    fi
}

deploy-sha-to-prod() {
    if [[ -z "$1" ]]; then
        echo "Usage: deploy-sha-to-prod <commit-sha>"
        return 1
    fi
    _deploy-sha citylitics-app-ci-cd-production crawler-147820 "$1"
}

deploy-sha-to-staging() {
