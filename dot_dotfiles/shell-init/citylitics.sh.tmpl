# Helper to consistently resolve the Citylitics repo root
# Usage:
#   citylitics-repo-root           # errors if not in a git repo
#   citylitics-repo-root --allow-default  # falls back to the default repo path
citylitics-repo-root() {
    local allow_default=0
    if [[ $1 == "--allow-default" ]]; then
        allow_default=1
        shift
    fi

    local ROOT_PREFIX="$HOME/watrhub-django"
    local DEFAULT_ROOT="$HOME/watrhub-django/main"

    local repo_root
    if ! repo_root=$(git rev-parse --show-toplevel 2>/dev/null); then
        if [[ $allow_default -eq 1 ]]; then
            repo_root="$DEFAULT_ROOT"
        else
            echo "Error: not in a git repository (expected somewhere under $ROOT_PREFIX)." >&2
            return 1
        fi
    fi

    case "$repo_root" in
    "$ROOT_PREFIX" | "$ROOT_PREFIX"/*) ;; # ok
    *)
        echo "Error: repository root '$repo_root' is not under '$ROOT_PREFIX'." >&2
        return 1
        ;;
    esac

    printf '%s' "$repo_root"
}

jira() {
    local branch="${1:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null)}"
    if [[ -z "$branch" ]]; then
        echo "Usage: jira [branch-name]"
        return 1
    fi
    local ticket
    ticket=$(echo "$branch" | grep -oE '[A-Z]+-[0-9]+' | head -1)
    if [[ -z "$ticket" ]]; then
        echo "No Jira ticket ID found in: $branch"
        return 1
    fi
    open "https://citylitics.atlassian.net/browse/$ticket"
}

